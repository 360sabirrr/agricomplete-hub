DATABASE_URL=sqlite:///agricomplete.db
JWT_SECRET_KEY=change_this_secret

# Optional: enables real LLM responses in the AI assistant.
# Recommended: Google Gemini API.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-2.0-flash,gemini-2.0-flash-lite
# GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/{model}:generateContent

# OPENAI_API_KEY works with the default OpenAI-compatible chat endpoint.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: use another OpenAI-compatible provider instead.
# LLM_API_KEY=
# LLM_API_URL=https://api.openai.com/v1/chat/completions
# LLM_MODEL=gpt-4o-mini

# No-key option: run a local Ollama model on your computer.
# Install Ollama, then run: ollama pull llama3.2:3b
OLLAMA_MODEL=llama3.2:3b
OLLAMA_API_URL=http://127.0.0.1:11434/api/chat
OLLAMA_TIMEOUT_SECONDS=5
