# Relative SQLite files are stored under backend/instance.
DATABASE_URL=sqlite:///agricomplete.db
# Generate a unique value, for example: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=
JWT_ACCESS_TOKEN_MINUTES=60

# Optional: enables real LLM responses in the AI assistant.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto
OPENROUTER_FALLBACK_MODELS=
OPENROUTER_TIMEOUT_SECONDS=24
# OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
# OPENROUTER_SITE_URL=http://localhost:5000
# OPENROUTER_APP_NAME=AgriComplete Hub
